{
  "name": "@roubo/electron",
  "version": "0.0.0",
  "productName": "Roubo",
  "description": "Local development environment manager for parallel worktree-based development.",
  "author": "David Poxon",
  "license": "Apache-2.0",
  "homepage": "https://github.com/davidpoxon/roubo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidpoxon/roubo.git",
    "directory": "electron"
  },
  "bugs": {
    "url": "https://github.com/davidpoxon/roubo/issues"
  },
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron-forge start",
    "start:dev": "cross-env ROUBO_DEV=1 electron-forge start",
    "build": "tsc",
    "prepackage:deps": "npm install --prefix . --omit=dev --no-save --package-lock=false --workspaces=false --install-strategy=nested",
    "build:icons": "node scripts/build-icons.mjs",
    "make": "tsc && node scripts/copy-resources.mjs && npm run build:icons && npm run prepackage:deps && electron-forge make",
    "publish": "tsc && node scripts/copy-resources.mjs && npm run build:icons && npm run prepackage:deps && electron-forge publish"
  },
  "ts-node": {
    "esm": true
  },
  "dependencies": {
    "node-pty": "1.1.0",
    "update-electron-app": "3.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "png2icons": "2.0.1",
    "sharp": "0.34.5",
    "@electron-forge/maker-deb": "7.11.1",
    "@reforged/maker-appimage": "5.2.0",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
    "@electron-forge/publisher-github": "7.11.1",
    "@electron-forge/shared-types": "7.11.1",
    "@electron/rebuild": "4.0.4",
    "@types/node": "25.6.0",
    "electron": "41.3.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
