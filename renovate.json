{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "30 days",
  "commitBody": "Signed-off-by: renovate[bot] <29139614+renovate[bot]@users.noreply.github.com>",
  "packageRules": [
    {
      "description": "Automerge patch devDependency updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Require manual review for all major version bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "dependencies"]
    },
    {
      "description": "Group ESLint ecosystem upgrades together",
      "groupName": "eslint ecosystem",
      "matchPackageNames": ["/^eslint/", "/^@eslint//", "/globals/", "/typescript-eslint/"]
    },
    {
      "description": "Group Vite ecosystem upgrades together",
      "groupName": "vite ecosystem",
      "matchPackageNames": ["/^vite/", "/^@vitejs//", "/^vitest/", "/^@vitest//"]
    }
  ]
}
