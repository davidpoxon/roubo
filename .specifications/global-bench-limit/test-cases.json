    {
      "id": "TC-008",
      "title": "In-flight bench reservation is visible to a parallel create attempt",
      "area": "bench-manager",
      "level": 1,
      "type": "integration",
      "preconditions": ["benches.maxGlobal = 4", "benches Map size = 3"],
      "steps": [
        {
          "id": "S001",
          "instruction": "Begin createBench A; pause inside async provisioning (status = preparing)",
          "observations": [
            {
              "id": "S001-O01",
              "expected": "Map size is now 4 (slot reserved before await)"
            }
          ]
        },
        {
          "id": "S002",
          "instruction": "While A is still in flight, call createBench B",
          "observations": [
            {
              "id": "S002-O01",
              "expected": "B rejects synchronously with GLOBAL_CAP_REACHED 409"
            }
          ]
        }
      ],
      "tags": ["concurrency", "automated"],
      "linked_requirement_ids": ["FR-005", "FR-006"],
      "linked_user_story_ids": []
    },
