    {
      "id": "TC-023",
      "title": "Two concurrent create requests at boundary: exactly one succeeds",
      "area": "bench-manager",
      "level": 2,
      "type": "integration",
      "preconditions": ["benches.maxGlobal = 3", "benches Map size = 2"],
      "steps": [
        {
          "id": "S001",
          "instruction": "Fire POST /api/projects/proj-a/benches and POST /api/projects/proj-b/benches in parallel",
          "observations": [
            {
              "id": "S001-O01",
              "expected": "Exactly one returns 201; the other returns 409 GLOBAL_CAP_REACHED"
            },
