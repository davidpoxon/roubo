      "id": "TC-021",
      "title": "End-to-end: user sets a cap, creates benches up to it, button disables, clears one, re-enables",
      "area": "e2e",
      "level": 2,
      "type": "functional",
      "preconditions": ["Fresh install, no cap, no benches"],
      "steps": [
        {
          "id": "S001",
          "instruction": "Open Settings > Benches; select Limit; enter 2; blur the field",
          "observations": [
            {
              "id": "S001-O01",
              "expected": "The value persists immediately (no Save button)"
            },
            {
              "id": "S001-O02",
              "expected": "benches.maxGlobal is 2"
            }
          ]
        },
        {
          "id": "S002",
          "instruction": "Navigate to BenchesTab; create bench A",
          "observations": [
            {
              "id": "S002-O01",
              "expected": "GlobalBenchMeter shows '1 of 2'"
            },
            {
              "id": "S002-O02",
              "expected": "'Set up bench' button still enabled"
            }
          ]
        },
        {
          "id": "S003",
          "instruction": "Create bench B",
          "observations": [
            {
              "id": "S003-O01",
              "expected": "GlobalBenchMeter shows '2 of 2' in red"
            },
            {
              "id": "S003-O02",
              "expected": "'Set up bench' button aria-disabled with cap-reached tooltip"
            }
          ]
        },
        {
          "id": "S004",
          "instruction": "Clear bench A",
          "observations": [
            {
              "id": "S004-O01",
              "expected": "GlobalBenchMeter shows '1 of 2' in neutral colour"
            },
            {
              "id": "S004-O02",
              "expected": "'Set up bench' button re-enables"
            }
          ]
        }
      ],
      "tags": ["happy-path", "e2e"],
      "linked_requirement_ids": ["FR-003", "FR-007", "FR-009", "FR-010"],
      "linked_user_story_ids": ["US-001", "US-002", "US-003"]
