    {
      "id": "TC-007",
      "title": "createBench returns 409 GLOBAL_CAP_REACHED when global count = cap",
      "area": "bench-manager",
      "level": 1,
      "type": "functional",
      "preconditions": ["benches.maxGlobal = 3", "benches Map size = 3"],
      "steps": [
        {
          "id": "S001",
          "instruction": "POST /api/projects/proj-a/benches",
