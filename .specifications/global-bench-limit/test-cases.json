    {
      "id": "TC-001",
      "title": "PUT /api/settings accepts absent benches.maxGlobal (unlimited)",
      "area": "settings",
      "level": 1,
      "type": "functional",
      "preconditions": ["Server is running with no existing settings.json"],
      "steps": [
        {
          "id": "S001",
          "instruction": "PUT /api/settings with body { theme: 'dark' } (no benches block)",
          "observations": [
            {
              "id": "S001-O01",
              "expected": "200 OK"
            },
            {
              "id": "S001-O02",
              "expected": "Response body has no benches.maxGlobal field"
            }
          ]
        },
        {
          "id": "S002",
          "instruction": "GET /api/settings",
          "observations": [
            {
              "id": "S002-O01",
              "expected": "benches.maxGlobal is absent or null"
            }
          ]
        }
      ],
      "tags": ["smoke", "backcompat", "automated"],
      "linked_requirement_ids": ["FR-001", "FR-002"],
      "linked_user_story_ids": ["US-005"]
    },
