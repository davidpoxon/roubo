{
  "name": "roubo",
  "version": "0.0.0",
  "private": true,
  "description": "Local development environment manager for parallel worktree-based development.",
  "author": "David Poxon",
  "license": "Apache-2.0",
  "homepage": "https://github.com/davidpoxon/roubo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidpoxon/roubo.git"
  },
  "bugs": {
    "url": "https://github.com/davidpoxon/roubo/issues"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "type": "module",
  "workspaces": [
    "shared",
    "plugin-sdk",
    "server",
    "client",
    "electron",
    "plugins/_shared-github",
    "plugins/github-com",
    "plugins/process",
    "plugins/database",
    "e2e/fixtures/stubbed-plugin",
    "e2e/fixtures/clasp-deploy-stub"
  ],
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git rev-parse --git-dir',{stdio:'ignore'});require('child_process').execSync('git config core.hooksPath scripts/git-hooks',{stdio:'inherit'});require('fs').chmodSync('scripts/git-hooks/commit-msg',0o755)}catch{}\"",
    "dev": "npm run dev --prefix server & npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix plugin-sdk && npm run build --prefix client && npm run build --prefix server && npm run build --prefix plugins/_shared-github && npm run build --prefix plugins/github-com && npm run build --prefix plugins/process && npm run build --prefix plugins/database && npm run build --prefix e2e/fixtures/stubbed-plugin && npm run build --prefix e2e/fixtures/clasp-deploy-stub",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "electron:dev": "concurrently -k -n vite,server,electron -c cyan,magenta,yellow \"npm run dev:client\" \"npm run dev:server\" \"npm run start:dev --prefix electron\"",
    "electron:start": "npm run start --prefix electron",
    "electron:make": "npm run build && npm run make --prefix electron",
    "electron:publish": "npm run publish --prefix electron",
    "release:draft": "node scripts/draft-release.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "lint:em-dash": "node scripts/check-em-dashes.mjs",
    "lint:component-guard": "node scripts/component-type-knowledge-guard.mjs",
    "lint:no-ai-coauthor": "node scripts/check-ai-coauthorship.mjs",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npx -w plugin-sdk tsc --noEmit && npx -w client tsc --noEmit && npx -w server tsc --noEmit && tsc --build tsconfig.build.json && npx -w plugins/process tsc --noEmit && npx -w plugins/database tsc --noEmit && npx -w e2e/fixtures/stubbed-plugin tsc --noEmit && npx -w e2e/fixtures/clasp-deploy-stub tsc --noEmit"
  },
  "dependencies": {
    "@roubo/shared": "file:./shared",
    "ajv": "8.20.0",
    "cors": "2.8.6",
    "dockerode": "5.0.0",
    "express": "5.2.1",
    "node-pty": "1.1.0",
    "octokit": "5.0.5",
    "semver": "7.8.5",
    "tree-kill": "1.2.2",
    "undici": "8.5.0",
    "vscode-jsonrpc": "9.0.0",
    "ws": "8.21.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/semver": "7.7.1",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "axe-core": "4.12.1",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9",
    "vitest-axe": "0.1.0"
  },
  "overrides": {
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "@electron/rebuild": "4.0.4",
    "protobufjs": "7.6.3",
    "esbuild": "0.28.1"
  }
}
