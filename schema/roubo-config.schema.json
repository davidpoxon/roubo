{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Roubo Configuration",
  "description": "Schema for roubo.yaml project bench configuration",
  "type": "object",
  "required": ["project", "layout", "benches"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "displayName", "repo"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "displayName": { "type": "string" },
        "repo": { "type": "string" },
        "github": {
          "type": "object",
          "properties": {
            "project": { "type": "integer" }
          },
          "additionalProperties": false
        }
      }
    },
    "layout": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["meta-repo", "monorepo", "single-repo"] },
        "submodules": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "components": {
      "type": "object",
      "description": "Each component binds to a component plugin plus an opaque config block the plugin's own configSchema validates (FR-003).",
      "additionalProperties": {
        "type": "object",
        "required": ["plugin"],
        "additionalProperties": false,
        "properties": {
          "plugin": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": false,
            "description": "Reference to the component plugin this component binds to.",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "The component plugin's manifest id."
              },
              "source": {
                "type": "string",
                "minLength": 1,
                "description": "Optional source (e.g. git URL or path) the plugin is loaded from."
              }
            }
          },
          "config": {
            "type": "object",
            "description": "Plugin-defined, opaque-to-roubo config block, validated against the bound plugin's manifest configSchema.",
            "additionalProperties": true
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of components that must be started before this one"
          }
        }
      }
    },
    "ports": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["base"],
        "additionalProperties": false,
        "properties": {
          "base": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "https": { "type": "boolean" }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "icon", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "type": { "type": "string", "enum": ["browser", "shell"] },
          "url": { "type": "string" },
          "command": { "type": "string" },
          "requires": { "type": "string" },
          "login": {
            "type": "object",
            "required": ["steps"],
            "additionalProperties": false,
            "properties": {
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["selector", "action"],
                  "additionalProperties": false,
                  "properties": {
                    "selector": { "type": "string" },
                    "action": { "type": "string", "enum": ["fill", "click"] },
                    "value": { "type": "string", "minLength": 1 }
                  },
                  "if": { "properties": { "action": { "const": "fill" } }, "required": ["action"] },
                  "then": { "required": ["value"] }
                }
              }
            }
          }
        },
        "if": { "properties": { "type": { "const": "shell" } }, "required": ["type"] },
        "then": { "not": { "required": ["login"] } }
      }
    },
    "inspection": {
      "type": "object",
      "required": ["framework", "directory", "command"],
      "additionalProperties": false,
      "properties": {
        "framework": { "type": "string" },
        "directory": { "type": "string" },
        "command": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "benches": {
      "type": "object",
      "required": ["max"],
      "additionalProperties": false,
      "properties": {
        "max": { "type": "integer", "minimum": 1, "maximum": 99 },
        "setup": { "type": "string", "description": "Command to run once at workspace root before components start. Runs through your login shell, so shell syntax works: chaining with &&, redirection, and pipes. On zsh the shell is also interactive so ~/.zshrc loads, which is what makes version managers such as nvm, fnm, and asdf resolve. On bash and other shells only the login profile files load (~/.bash_profile, ~/.profile, not ~/.bashrc), so a version-manager snippet installed into ~/.bashrc must be moved into the profile file to resolve here." },
        "autoClear": { "type": "boolean", "description": "Automatically clear benches when their assigned issue moves to Done or is closed. Defaults to true." }
      }
    },
    "jigs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultJig": { "type": "string" },
        "issueTypeMappings": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plugin": { "type": "string" },
        "instance": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": ["string", "number"] },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["externalId"],
                  "properties": {
                    "externalId": { "type": ["string", "number"] },
                    "project": { "type": "string" },
                    "boardMode": { "type": "string", "enum": ["active-sprint", "whole-board"] },
                    "mineScope": { "type": "string", "enum": ["in-project", "anywhere"] },
                    "excludedStatuses": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "includeCodeQLAlerts": { "type": "boolean" },
                    "includeSecretScanningAlerts": { "type": "boolean" },
                    "includeDependabotAlerts": { "type": "boolean" }
                  }
                }
              ]
            }
          }
        },
        "pluginSource": { "type": "string" },
        "excludedStatuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Per-project layer of the three-layer excludedStatuses merge. Plugin-global defaults live in plugin manifests; per-source overrides ride on each sources[<cat>][<i>] object entry."
        },
        "excludedStatusCategories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Category-first default exclusion (e.g. \"Done\"), user-editable, ANDed into the JQL alongside excludedStatuses. Plugin-global default is seeded in the plugin manifest."
        }
      }
    },
    "users": {
      "type": "array",
      "description": "List of users to seed in the bench environment. Only non-sensitive properties should be stored here. Do not commit passwords or secrets directly; use environment variable references instead.",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["name", "properties"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "marketplaces": {
      "type": "array",
      "description": "Optional third-party plugin marketplaces this project declares so the project-open flow can offer to register them. Each entry is a URL only, never a credential. Declaring this block requires an app version that supports it.",
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://",
            "description": "The marketplace base URL (http or https only). Never a credential."
          }
        }
      }
    }
  }
}
